{
  "name": "markdown-stick-notes",
  "version": "0.2.6",
  "description": "Markdown Sticky Notes web extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:edge": "wxt zip -b edge",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "zip:all": "pnpm run zip && pnpm run zip:edge && pnpm run zip:firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/view": "^6.40.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "@uiw/codemirror-themes-all": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "@uiw/react-color": "^2.9.6",
    "re-resizable": "^6.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.3",
    "react-syntax-highlighter": "npm:@fengkx/react-syntax-highlighter@15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rooks": "^7.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.5",
    "wxt": "^0.20.20"
  },
  "pnpm": {
    "overrides": {
      "@babel/helpers": "7.29.2",
      "@babel/runtime": "7.29.2",
      "giget": "3.1.2",
      "mdast-util-to-hast": "13.2.1",
      "multimatch@6>minimatch": "3.1.5",
      "minimatch@3.1.5>brace-expansion": "1.1.12",
      "node-forge": "1.3.3",
      "prismjs": "1.30.0",
      "rollup": "4.59.0"
    }
  }
}